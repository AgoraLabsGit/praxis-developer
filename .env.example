# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# Key encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Optional: if not set, keys are stored in plaintext (backward compatible)
ENCRYPTION_KEY=your_64_character_hex_key_here

# GitHub OAuth (get from github.com/settings/developers)
GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx

# OpenRouter
OPENROUTER_API_KEY=sk-or-xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
